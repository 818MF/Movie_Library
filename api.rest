@rootUrl = http://localhost:3002
@baseUrl = http://localhost:3002/api
@authToken = your_auth_token_here

### Health (JSON — vérifie que le serveur répond)
GET {{rootUrl}}/health

### Register a new user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "email": "test@example.com",
    "password": "password123"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "test@example.com",
    "password": "password123"
}

### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{authToken}}

### Search movies
GET {{baseUrl}}/movies/search?query=inception
Authorization: Bearer {{authToken}}

### Get all favorite movies
GET {{baseUrl}}/movies
Authorization: Bearer {{authToken}}

### Add movie to favorites
POST {{baseUrl}}/movies
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "tmdbId": 27205
}

### Update movie note and rating
PUT {{baseUrl}}/movies/movie_id_here
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "personalNote": "Great movie!",
    "rating": 9
}

### Delete movie from favorites
DELETE {{baseUrl}}/movies/movie_id_here
Authorization: Bearer {{authToken}} 